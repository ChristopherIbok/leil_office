{
  "name": "leilportal",
  "version": "0.1.0",
  "private": true,
  "description": "LEILPORTAL monorepo for a secure digital office SaaS.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "dev:api": "npm run dev -w @leilportal/api",
    "dev:web": "npm run dev -w @leilportal/web",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "prisma:generate": "npx prisma generate --schema=./schema.prisma",
    "prisma:migrate": "npx prisma migrate dev --schema=./schema.prisma"
  },
  "engines": {
    "node": ">=20.11.0"
  },
  "devDependencies": {
    "@types/nodemailer": "^8.0.0",
    "typescript": "^5.6.3"
  }
}
