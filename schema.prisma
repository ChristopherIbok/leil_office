generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  TEAM_MEMBER
  CLIENT
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  COMPLETED
  ON_HOLD
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  DONE
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  password      String
  role          Role      @default(CLIENT)
  projects      Project[] @relation("ProjectParticipants")
  clientProjects Project[] @relation("ClientAccount")
  managedProjects Project[] @relation("ProjectManager")
  tasks         Task[]    @relation("TaskAssignee")
  comments      Comment[]
  messages      Message[]
  timeLogs      TimeLog[]
  files         File[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Project {
  id          String        @id @default(cuid())
  name        String
  description String?
  status      ProjectStatus @default(PLANNING)
  clientId    String
  managerId   String
  manager     User          @relation("ProjectManager", fields: [managerId], references: [id])
  client      User          @relation("ClientAccount", fields: [clientId], references: [id])
  members     User[]        @relation("ProjectParticipants")
  tasks       Task[]
  files       File[]
  createdAt   DateTime      @default(now())
}

model Task {
  id          String     @id @default(cuid())
  title       String
  description String?
  status      TaskStatus @default(TODO)
  dueDate     DateTime?
  projectId   String
  project     Project    @relation(fields: [projectId], references: [id])
  assigneeId  String?
  assignee    User?      @relation("TaskAssignee", fields: [assigneeId], references: [id])
  comments    Comment[]
  timeLogs    TimeLog[]
  createdAt   DateTime   @default(now())
}

model File {
  id          String   @id @default(cuid())
  url         String
  filename    String
  version     Int      @default(1)
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id])
  uploadedBy  String
  uploader    User     @relation(fields: [uploadedBy], references: [id])
  createdAt   DateTime @default(now())
}

model Message {
  id        String   @id @default(cuid())
  content   String
  senderId  String
  sender    User     @relation(fields: [senderId], references: [id])
  channelId String   // Project ID or Direct Chat ID
  createdAt DateTime @default(now())
}

model TimeLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id])
  duration  Int      // Seconds
  date      DateTime @default(now())
}